NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public application URL used for PayFast return, cancel, and notify URLs.
# Example: https://your-production-domain.co.za
NEXT_PUBLIC_APP_URL=

# PayFast live subscription credentials. Do not use sandbox credentials here.
PAYFAST_MERCHANT_ID=35841129
PAYFAST_MERCHANT_KEY=gwa8tuk9oe87x
PAYFAST_PASSPHRASE=Deep00my5un4is3

# Optional override for PayFast ITN source validation. If omitted, the app uses
# the current official PayFast CIDR ranges captured from the PayFast docs.
# Comma-separated IPs/CIDRs, for example: 197.97.145.144/28,41.74.179.192/27
PAYFAST_VALID_IPS=

# Cloudflare R2 (separate provider from Supabase) used to store daily database
# backups. Create a bucket and an Account API Token (Object Read & Write,
# scoped to the bucket, no expiration, no IP filtering) at
# https://dash.cloudflare.com/?to=/:account/r2/overview
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
