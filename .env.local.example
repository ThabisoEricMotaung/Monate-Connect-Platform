NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public application URL used for PayFast return, cancel, and notify URLs.
# Example: https://your-production-domain.co.za
NEXT_PUBLIC_APP_URL=

# PayFast live subscription credentials. Do not use sandbox credentials here.
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=

# Optional override for PayFast ITN source validation. If omitted, the app uses
# the current official PayFast CIDR ranges captured from the PayFast docs.
# Comma-separated IPs/CIDRs, for example: 197.97.145.144/28,41.74.179.192/27
PAYFAST_VALID_IPS=
